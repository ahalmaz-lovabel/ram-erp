// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== SHARED: AUDIT =====
// سجل التدقيق المالي/الإداري: "مين عمل إيه" على مستوى العمل نفسه.
// منفصل تمامًا عن السجلات التقنية (logger/Pino). كل عملية حساسة
// (إنشاء، تعديل، اعتماد، إلغاء، أرشفة) تُسجَّل هنا عبر recordAuditLog().
model AuditLog {
  id       String  @id @default(cuid())
  // معرف المستخدم اللي نفّذ العملية. String دلوقتي (بدون FK) لأن موديول
  // users لسه ما اتبناش — تتحوّل لعلاقة فعلية مع User وقت بناء users.
  userId   String
  module   String // اسم الموديول (users, invoices, inventory...)
  action   String // نوع العملية (create, update, approve, archive, cancel...)
  entityId String? // معرف الكيان المتأثر (لو ينطبق)
  oldValue Json? // snapshot للقيمة قبل التعديل
  newValue Json? // snapshot للقيمة بعد التعديل

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([module, action])
  @@index([entityId])
  @@index([createdAt])
}

// ===== SHARED: SEQUENCES =====
// عدّادات الترقيم التسلسلي الآمنة من التعارض (فواتير، عروض، صفقات، أوامر...).
// الزيادة تتم ذريًا (atomic) داخل transaction عبر sequenceGenerator.
model Sequence {
  key   String @id // مفتاح العدّاد، مثل "deal" أو "invoice"
  value Int    @default(0)
}

// ===== USERS =====
// موديول المستخدمين والأدوار والصلاحيات. مبني على docs/analysis/users-analysis.md
// مبدأ أساسي: المنع الافتراضي — لا صلاحية إلا إذا مُنحت صراحة.

// القسم/الإدارة التابع لها المستخدم أو الدور (تحليل §3، §5).
enum Department {
  sales // مبيعات
  accounts // حسابات
  warehouse // مخازن
  production // إنتاج
  purchasing // مشتريات
  management // إدارة
  shipping // شحن وتركيب
  website // موقع إلكتروني ومحتوى
}

// حالة حساب المستخدم (تحليل §3، §10).
enum UserStatus {
  active // نشط
  suspended // موقوف مؤقتًا (يمنع الدخول مع الاحتفاظ بالسجلات)
  locked // مقفل أمنيًا (محاولات دخول فاشلة أو اشتباه اختراق)
  archived // مؤرشف (موظف سابق/غير نشط)
}

// حالة الدور (تحليل §5).
enum RoleStatus {
  active // نشط
  suspended // موقوف
  archived // مؤرشف
}

// مستوى سلطة الدور (تحليل §4). المالك أعلى سلطة وخفي ومحمي، ومدير النظام
// واسع الصلاحيات دون امتلاك كامل، وبقية الأدوار تشغيلية.
enum RoleLevel {
  owner // مالك النظام
  admin // مدير النظام
  standard // دور تشغيلي عادي
}

// نوع الاستثناء على مستوى المستخدم (تحليل §11): منح إضافي أو سحب استثنائي.
enum PermissionEffect {
  grant // صلاحية إضافية ممنوحة مباشرة للمستخدم فوق دوره
  revoke // صلاحية مسحوبة من المستخدم رغم وجودها في دوره
}

// الدور: قالب صلاحيات يُربط بالمستخدمين (تحليل §5).
model Role {
  id          String      @id @default(cuid())
  name        String      @unique // اسم الدور، مثل "موظف مبيعات"
  key         String      @unique // معرّف ثابت (slug)، مثل "sales-rep"
  description String? // وصف الدور والغرض منه
  department  Department? // القسم المرتبط بالدور إن وجد
  level       RoleLevel   @default(standard)
  isSystem    Boolean     @default(false) // نظامي ثابت أم دور مخصص أنشأته الإدارة
  status      RoleStatus  @default(active)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  permissions RolePermission[]
  users       User[]

  @@index([status])
  @@index([level])
  @@index([department])
}

// ربط دور بمفتاح صلاحية واحد (تحليل §5، §6).
model RolePermission {
  id            String   @id @default(cuid())
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionKey String // مفتاح الصلاحية، مثل "invoices.approve"
  createdAt     DateTime @default(now())

  @@unique([roleId, permissionKey])
  @@index([roleId])
  @@index([permissionKey])
}

// المستخدم: حساب دخول مستقل (تحليل §3).
model User {
  id           String      @id @default(cuid())
  fullName     String // الاسم الكامل
  email        String      @unique // بريد/اسم مستخدم للدخول
  phone        String?
  whatsapp     String?
  department   Department? // القسم أو الإدارة
  jobTitle     String? // المسمى الوظيفي
  roleId       String // الدور الأساسي
  role         Role        @relation(fields: [roleId], references: [id])
  status       UserStatus  @default(active)
  // مالك النظام: خفي من القوائم العادية ومحمي من أي تعديل/إيقاف من غيره (تحليل §4).
  isSystemOwner Boolean    @default(false)

  passwordHash         String // كلمة المرور مشفّرة — ممنوع حفظها كنص صريح (تحليل §13)
  mustChangePassword   Boolean   @default(true) // إجبار تغيير كلمة المرور عند أول دخول
  lastLoginAt          DateTime?
  lastPasswordChangeAt DateTime?
  adminNotes           String? // ملاحظات إدارية داخلية

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  directPermissions    UserPermissionGrant[]
  sessions             Session[]
  responsibleCustomers Customer[]
  responsibleDeals     Deal[]

  @@index([roleId])
  @@index([status])
  @@index([department])
}

// جلسة دخول مستقلة لكل جهاز/متصفح (تحليل §13، §14). نخزّن hash للتوكن فقط
// — التوكن الخام يعيش في كوكي httpOnly عند العميل ولا يُحفظ في قاعدة البيانات.
model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique // SHA-256 للتوكن — مش التوكن نفسه
  expiresAt  DateTime
  revokedAt  DateTime? // إنهاء الجلسة يدويًا (تسجيل خروج/إنهاء كل الجلسات)
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// سجل محاولات الدخول — أساس القفل الأمني بعد محاولات فاشلة متكررة (تحليل §13).
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String // البريد المُدخل (حتى لو مش موجود، لمنع تعداد الحسابات)
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

// استثناء صلاحية على مستوى مستخدم واحد (تحليل §11): منح إضافي أو سحب.
// السبب المكتوب مطلوب للعمليات الحساسة (تحليل §11، §15، §21).
model UserPermissionGrant {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionKey   String
  effect          PermissionEffect
  reason          String? // سبب مكتوب (مطلوب للصلاحيات الحساسة)
  createdByUserId String? // مين منح/سحب الصلاحية
  createdAt       DateTime         @default(now())

  @@unique([userId, permissionKey])
  @@index([userId])
}

// ===== PRODUCTS: مكتبة الخامات + مكتبة السمات (مرحلة 1أ) =====
// مبني على docs/analysis/products-analysis.md (§7، §8). المنتجات نفسها والوصفات
// ومحرك التكلفة يأتون في المرحلة التالية.

// وحدات القياس المستخدمة في الشراء والحساب (تحليل §8 + إضافة التكلفة الهرمية).
// كل وحدة تنتمي لبُعد (dimension): عدد/طول/مساحة/حجم/وزن/سعة — راجع unitDimension().
enum MeasurementUnit {
  ton // طن (وزن)
  kg // كيلو (وزن)
  gram // جرام (وزن)
  meter // متر (طول)
  cm // سم (طول)
  mm // مم (طول)
  squareMeter // متر مربع (مساحة)
  squareCm // سم مربع (مساحة)
  cubicMeter // متر مكعب (حجم)
  cubicCm // سم مكعب (حجم)
  liter // لتر (سعة)
  ml // مل (سعة)
  roll // رول (عدد)
  box // علبة (عدد)
  piece // قطعة (عدد)
}

// نموذج تكلفة عملية التصنيع (مكتبة العمليات).
enum OperationCostModel {
  fixed // مبلغ ثابت لكل قطعة/تطبيق
  perTime // سعر × زمن
  perQuantity // سعر × كمية
  percentage // نسبة من تكلفة الخامات
}

enum MaterialStatus {
  active // نشطة
  suspended // موقوفة
  archived // مؤرشفة
}

// مكتبة الخامات: المرجع المركزي للخامات وأسعارها لحساب التكلفة تلقائيًا (تحليل §8).
// كل الحقول المالية Decimal (قاعدة CLAUDE #3).
model Material {
  id          String         @id @default(cuid())
  code        String         @unique // كود الخامة
  name        String
  category    String // حديد، مواسير، صاج، جلد، إسفنج، دهان... (مفتوح)
  description String?
  imageUrl    String? // صورة الخامة
  // معامل التحويل: كام وحدة حساب في وحدة الشراء (مثال: 1 طن = 1000 كجم ⇒ 1000).
  purchaseUnit     MeasurementUnit
  baseUnit         MeasurementUnit
  conversionFactor Decimal
  // سعر وحدة الشراء، وسعر أقل وحدة (baseUnitPrice = purchaseUnitPrice / conversionFactor).
  purchaseUnitPrice Decimal
  baseUnitPrice     Decimal
  lastPurchasePrice Decimal?
  avgPurchasePrice  Decimal?
  status            MaterialStatus @default(active)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  priceHistory MaterialPriceHistory[]
  bomItems     ComponentMaterial[]

  @@index([status])
  @@index([category])
}

// سجل تغيّر أسعار الخامة مع التاريخ والسبب والمستخدم (تحليل §8).
model MaterialPriceHistory {
  id                    String   @id @default(cuid())
  materialId            String
  material              Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  oldPurchaseUnitPrice  Decimal?
  newPurchaseUnitPrice  Decimal
  oldBaseUnitPrice      Decimal?
  newBaseUnitPrice      Decimal
  reason                String?
  changedByUserId       String
  createdAt             DateTime @default(now())

  @@index([materialId])
  @@index([createdAt])
}

// نوع السمة (تحليل §7).
enum AttributeType {
  text // نص
  number // رقم
  list // اختيار من قائمة
  boolean // نعم/لا
  unit // وحدة قياس
  color // لون
  file // ملف
  image // صورة
}

// مكتبة السمات: قاموس مركزي للخصائص المستدعاة داخل المنتجات (تحليل §7).
model Attribute {
  id            String           @id @default(cuid())
  name          String           @unique // اللون، المقاس، الوزن...
  type          AttributeType
  unit          MeasurementUnit? // وحدة القياس إن وجدت
  isRequired    Boolean          @default(false)
  showInQuotes  Boolean          @default(false)
  showOnWebsite Boolean          @default(false)
  usedInFilter  Boolean          @default(false)
  internalOnly  Boolean          @default(false)
  displayOrder  Int              @default(0)
  archivedAt    DateTime? // أرشفة بدل الحذف (قاعدة CLAUDE #16)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  values AttributeValue[]

  @@index([archivedAt])
}

// القيم المسموحة لسمة من نوع list (تحليل §7).
model AttributeValue {
  id           String    @id @default(cuid())
  attributeId  String
  attribute    Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value        String
  displayOrder Int       @default(0)

  @@unique([attributeId, value])
  @@index([attributeId])
}

// مكتبة عمليات التصنيع (تحليل §10 + إضافة التكلفة الهرمية): عمليات معيارية
// قابلة لإعادة الاستخدام (قص، لحام، دهان، تنجيد، تجميع، تشغيل، تغليف، اختبار)
// بتكلفة معيارية. تُطبَّق على مكوّنات المنتج في مرحلة لاحقة (ComponentOperation).
model Operation {
  id           String             @id @default(cuid())
  name         String             @unique
  category     String? // تصنيف العملية (قص/لحام/دهان...)
  costModel    OperationCostModel
  standardCost Decimal // القيمة المعيارية (تفسيرها حسب costModel)
  description  String?
  archivedAt   DateTime? // أرشفة بدل الحذف (قاعدة CLAUDE #16)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  appliedIn ComponentOperation[]

  @@index([archivedAt])
  @@index([category])
}

// حالة المنتج (تحليل §6).
enum ProductStatus {
  active // نشط
  inactive // غير نشط
  suspended // موقوف
  archived // مؤرشف
}

// المنتج (تحليل §6). المرحلة 1ب-2: الهيكل + شجرة المكوّنات + التكلفة المجمّعة.
// التسعير والربحية والبيانات التسويقية تأتي في 1ب-3.
model Product {
  id             String        @id @default(cuid())
  code           String        @unique // كود المنتج (فريد)
  name           String
  status         ProductStatus @default(active)
  productionCost Decimal       @default(0) // تكلفة الإنتاج المجمّعة (cached من محرك التكلفة)
  manualCost     Decimal? // تكلفة يدوية اختيارية بديلة (§12، بصلاحية)
  costUpdatedAt  DateTime? // آخر إعادة حساب للتكلفة

  // التسعير والربحية (§12). الربح والهامش محسوبان من السعر والتكلفة الفعّالة.
  salePrice        Decimal? // سعر البيع الافتراضي
  minSalePrice     Decimal? // أقل سعر بيع مسموح
  minMarginPercent Decimal? // حد أدنى لهامش الربح (لتنبيه عند الانخفاض عنه)
  priceUpdatedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  components   Component[]
  priceHistory ProductPriceHistory[]
  costHistory  ProductCostHistory[]

  @@index([status])
}

// سجل تعديل سعر البيع (§13).
model ProductPriceHistory {
  id                     String   @id @default(cuid())
  productId              String
  product                Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldSalePrice           Decimal?
  newSalePrice           Decimal?
  oldMinSalePrice        Decimal?
  newMinSalePrice        Decimal?
  productionCostAtChange Decimal // تكلفة الإنتاج وقت التعديل
  marginBefore           Decimal?
  marginAfter            Decimal?
  reason                 String?
  changedByUserId        String
  createdAt              DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// سجل تغيّر تكلفة الإنتاج (§14). المصدر يوضّح سبب التغيير.
model ProductCostHistory {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldCost         Decimal
  newCost         Decimal
  // material_price | recipe | manual | recalc
  source          String
  changedByUserId String
  createdAt       DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// مكوّن في شجرة المنتج — ذاتي المرجع (تجميعة فرعية أو قطعة نهائية).
// مبني على مذكرة التصميم الهرمي (mBOM). المواصفات تُستخدم لاحقًا للورقة الفنية.
model Component {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  // شجرة: أب اختياري داخل نفس المنتج.
  parentId String?
  parent   Component?  @relation("ComponentTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Component[] @relation("ComponentTree")

  name     String
  quantity Decimal @default(1) // عدد النسخ داخل الأب (مثال: رجل ×2)

  // مواصفات اختيارية للورقة الفنية (§ ورقة فنية).
  lengthCm    Decimal?
  widthCm     Decimal?
  thicknessMm Decimal?
  weightKg    Decimal?
  notes       String?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materials  ComponentMaterial[]
  operations ComponentOperation[]

  @@index([productId])
  @@index([parentId])
}

// بند خامة في مكوّن (leaf BOM item). الوحدة لازم تكون نفس بُعد وحدة حساب الخامة.
model ComponentMaterial {
  id           String          @id @default(cuid())
  componentId  String
  component    Component       @relation(fields: [componentId], references: [id], onDelete: Cascade)
  materialId   String
  material     Material        @relation(fields: [materialId], references: [id])
  quantity     Decimal
  unit         MeasurementUnit
  wastePercent Decimal         @default(0)
  createdAt    DateTime        @default(now())

  @@index([componentId])
  @@index([materialId])
}

// عملية تصنيع مُطبّقة على مكوّن — snapshot لتكلفتها وقت التطبيق حتى لا يتغيّر
// تسعير قديم عند تعديل مكتبة العمليات. operationId اختياري (عملية استثنائية).
model ComponentOperation {
  id           String             @id @default(cuid())
  componentId  String
  component    Component          @relation(fields: [componentId], references: [id], onDelete: Cascade)
  operationId  String? // مرجع مكتبة العمليات (null لو استثنائية inline)
  operation    Operation?         @relation(fields: [operationId], references: [id])
  name         String // snapshot لاسم العملية
  costModel    OperationCostModel // snapshot
  standardCost Decimal // snapshot
  param        Decimal            @default(1) // الكمية/الزمن لـ perQuantity/perTime
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())

  @@index([componentId])
}

// ===== CUSTOMERS =====
// موديول العملاء وجهات التواصل والصفقات. مبني على docs/analysis/customers-analysis.md
// (§4، §5، §6). العروض/الفواتير/الدفعات/الضمانات تُبنى في موديولاتها وتُربط بالعميل.

enum CustomerType {
  person // شخص
  organization // مؤسسة
  company // شركة
  club // نادي
  gym // جيم
  distributor // موزع
}

enum CustomerStatus {
  prospect // محتمل
  active // نشط
  inactive // غير نشط
  archived // مؤرشف
}

// مصدر العميل/الصفقة (§4، §6).
enum CustomerSource {
  ad // إعلان
  referral // ترشيح
  visit // زيارة
  call // اتصال
  exhibition // معرض
  existing // عميل قديم
}

enum ContactDepartment {
  management // إدارة
  purchasing // مشتريات
  accounts // حسابات
  website // موقع
  receiving // استلام
}

enum DealStatus {
  interested // عميل مهتم
  contacting // جاري التواصل
  quote_sent // تم إرسال عرض سعر
  negotiation // مرحلة التفاوض
  accepted // مقبولة
  rejected // مرفوضة
  postponed // مؤجلة
  converted // تحوّلت لأمر بيع
  cancelled // ملغاة
}

enum DealType {
  direct_sale // بيع مباشر
  gym_setup // تجهيز جيم
  supply_only // توريد فقط
  supply_install // توريد وتركيب
  later_addition // إضافة لاحقة
}

// العميل: فرد أو مؤسسة (§4). "عليه مديونية" فلتر مشتق من الرصيد (accounting لاحقًا)،
// و"مهم" علم مستقل (isImportant). المستندات الرسمية تحفظ بيانات العميل وقت الإصدار.
model Customer {
  id                 String          @id @default(cuid())
  code               String          @unique
  name               String
  type               CustomerType
  status             CustomerStatus  @default(prospect)
  isImportant        Boolean         @default(false) // عميل مهم
  phone              String?
  whatsapp           String?
  email              String?
  address            String?
  city               String?
  country            String?
  taxNumber          String?
  commercialRegister String?
  source             CustomerSource?
  notes              String?
  responsibleUserId  String? // الموظف المسؤول
  responsibleUser    User?           @relation(fields: [responsibleUserId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  contacts       CustomerContact[]
  deals          Deal[]
  communications CustomerCommunication[]

  @@index([status])
  @@index([type])
  @@index([responsibleUserId])
}

// نوع التواصل مع العميل (§14).
enum CommunicationType {
  call // اتصال
  whatsapp // واتساب
  email // بريد
  visit // زيارة
  meeting // اجتماع
}

// سجل التواصل والمتابعة داخل ملف العميل (§14): ما تم والخطوة التالية.
model CustomerCommunication {
  id               String            @id @default(cuid())
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          CustomerContact?  @relation(fields: [contactId], references: [id])
  type             CommunicationType
  summary          String // ملخص ما حدث
  nextStep         String? // الخطوة التالية
  nextFollowUpDate DateTime? // موعد المتابعة القادمة
  createdByUserId  String // الموظف المسؤول عن المتابعة
  createdAt        DateTime          @default(now())

  @@index([customerId])
  @@index([nextFollowUpDate])
}

// جهة تواصل داخل العميل (§5). العميل قد يكون مؤسسة بأكثر من جهة.
model CustomerContact {
  id         String             @id @default(cuid())
  customerId String
  customer   Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  jobTitle   String?
  phone      String?
  whatsapp   String?
  email      String?
  isPrimary  Boolean            @default(false) // جهة التواصل الأساسية
  department ContactDepartment?
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  deals          Deal[]
  communications CustomerCommunication[]

  @@index([customerId])
}

// الصفقة: فرصة بيع/مشروع مع العميل (§6). رقمها تسلسلي عبر sequenceGenerator.
model Deal {
  id                String           @id @default(cuid())
  number            String           @unique // رقم الصفقة (DEAL-xxxxx)
  name              String
  customerId        String
  customer          Customer         @relation(fields: [customerId], references: [id])
  contactId         String?
  contact           CustomerContact? @relation(fields: [contactId], references: [id])
  responsibleUserId String?
  responsibleUser   User?            @relation(fields: [responsibleUserId], references: [id])
  source            CustomerSource?
  type              DealType
  estimatedValue    Decimal? // قيمة مالية → Decimal
  expectedCloseDate DateTime?
  status            DealStatus       @default(interested)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([responsibleUserId])
}
